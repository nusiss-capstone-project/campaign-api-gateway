# Railway provides a dynamic PORT env var; listen on that port.
:{$PORT}

# Match campaign-center-api requests.
@api_path path /campaign-center-api /campaign-center-api/*

# Match identity-ms requests.
@identity_ms_path path /identity-ms /identity-ms/*

# Match allowed browser origins for CORS.
@allowed_origin {
	expression `{http.request.header.Origin} == "https://campaign-center-admin-web.vercel.app" || {http.request.header.Origin} == "https://finverse-web.vercel.app" || {http.request.header.Origin} == "http://localhost:3000"`
}

# Properly answer CORS preflight requests from allowed origins.
@preflight {
	method OPTIONS
	expression `{http.request.header.Origin} == "https://campaign-center-admin-web.vercel.app" || {http.request.header.Origin} == "https://finverse-web.vercel.app" || {http.request.header.Origin} == "http://localhost:3000"`
}

route {
	# Simple health endpoint for uptime/readiness checks.
	respond /health "ok" 200

	# CORS response headers for allowed origins.
	header @allowed_origin Access-Control-Allow-Origin "{http.request.header.Origin}"
	header @allowed_origin Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
	header @allowed_origin Access-Control-Allow-Headers "{http.request.header.Access-Control-Request-Headers}"
	header @allowed_origin Access-Control-Allow-Credentials "true"
	header @allowed_origin Vary "Origin"

	respond @preflight "" 204

	# Handle API gateway traffic for campaign-center-api.
	# Using `handle` (not `handle_path`) keeps the full path prefix when proxying.
	handle @api_path {
		# Reverse proxy to the internal Railway service, preserving request path.
		reverse_proxy http://campaign-center-api.railway.internal:8080 {
			# The gateway owns CORS; strip upstream CORS headers to avoid browser-rejected duplicates.
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Allow-Credentials
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Max-Age
			header_down -Vary
		}
	}

	# Handle API gateway traffic for identity-ms.
	# Using `handle` (not `handle_path`) keeps the full path prefix when proxying.
	handle @identity_ms_path {
		reverse_proxy http://identity-mservice.railway.internal:8080 {
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Allow-Credentials
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Max-Age
			header_down -Vary
		}
	}

	# Return 404 for non-matching routes.
	respond "not found" 404
}
